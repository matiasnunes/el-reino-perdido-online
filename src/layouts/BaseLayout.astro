---
import Nav from '../components/Nav.astro';
import MapaModal from '../components/MapaModal.astro';

const { title = 'El Reino Perdido', description = 'Los profetas lo prometieron. Los apóstoles lo esperaron. La teología lo olvidó.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/1000-favicon.png" />
    <link rel="apple-touch-icon" href="/1000-favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <Nav />
    <MapaModal currentPath={currentPath} />
    <slot />
  </body>
</html>
