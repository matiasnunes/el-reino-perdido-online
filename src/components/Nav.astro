---
// Nav.astro — navegación global compartida entre todos los layouts.
// Para agregar una sección nueva: añadir un <a> al listado de abajo.
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="site-nav" aria-label="Navegación principal">
  <a href="/" class:list={['site-nav__link', { 'site-nav__link--active': isActive('/') }]}>
    Inicio
  </a>
  <!--<a href="/articulos" class:list={['site-nav__link', { 'site-nav__link--active': isActive('/articulos') }]}>
    Artículos
  </a>-->
  <a href="/contacto" class:list={['site-nav__link', { 'site-nav__link--active': isActive('/contacto') }]}>
    Contacto
  </a>
  <button
    class="site-nav__map-btn"
    id="mapa-trigger"
    aria-label="Abrir mapa del sitio"
    aria-expanded="false"
    aria-controls="mapa-modal"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
      <line x1="8" y1="2" x2="8" y2="18"/>
      <line x1="16" y1="6" x2="16" y2="22"/>
    </svg>
  </button>
</nav>
