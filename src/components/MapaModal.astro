---
const { currentPath = '/' } = Astro.props;
---

<script is:inline>
(function() {

  var modal = document.createElement('div');
  modal.id = 'mapa-modal';
  modal.style.cssText = 'display:none;position:fixed;inset:0;z-index:9998;align-items:center;justify-content:center;padding:1.5rem;';

  var backdrop = document.createElement('div');
  backdrop.style.cssText = 'position:absolute;inset:0;background:rgba(10,9,8,0.88);opacity:0;transition:opacity 0.25s ease;';

  var panel = document.createElement('div');
  panel.style.cssText = 'position:relative;z-index:1;width:100%;max-width:700px;max-height:88vh;overflow-y:auto;background:#1a1814;border:1px solid rgba(200,168,75,0.2);box-shadow:0 20px 60px rgba(0,0,0,0.7);padding:2.5rem 2.8rem 3rem;opacity:0;transform:translateY(16px);transition:opacity 0.25s ease,transform 0.25s ease;font-family:EB Garamond,Georgia,serif;';

  var header = document.createElement('div');
  header.style.cssText = 'text-align:center;margin-bottom:2.2rem;position:relative;';

  var ornLine = document.createElement('div');
  ornLine.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:1rem;margin-bottom:1rem;';
  ornLine.innerHTML = '<div style="width:40px;height:1px;background:linear-gradient(90deg,transparent,#d9c9a3,transparent);"></div><div style="width:6px;height:6px;background:#d9c9a3;transform:rotate(45deg);"></div><div style="width:40px;height:1px;background:linear-gradient(90deg,transparent,#d9c9a3,transparent);"></div>';

  var titulo = document.createElement('h2');
  titulo.textContent = 'Mapa del Reino';
  titulo.style.cssText = 'font-family:Cormorant Garamond,Georgia,serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:300;color:#ede0c4;margin-bottom:0.3rem;letter-spacing:0.04em;';

  var sub = document.createElement('p');
  sub.textContent = 'Elige tu camino';
  sub.style.cssText = 'font-family:Cormorant SC,serif;font-size:0.95rem;letter-spacing:0.3em;color:#7a6e5a;text-transform:uppercase;';

  var closeBtn = document.createElement('button');
  closeBtn.id = 'mapa-close';
  closeBtn.setAttribute('aria-label', 'Cerrar mapa');
  closeBtn.style.cssText = 'position:absolute;top:0;right:0;background:none;border:none;cursor:pointer;color:#7a6e5a;padding:0.25rem;line-height:0;transition:color 0.2s;';
  closeBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  closeBtn.onmouseenter = function() { closeBtn.style.color = '#d9c9a3'; };
  closeBtn.onmouseleave = function() { closeBtn.style.color = '#7a6e5a'; };

  header.appendChild(ornLine);
  header.appendChild(titulo);
  header.appendChild(sub);
  header.appendChild(closeBtn);

  var currentPath = document.location.pathname;

  var GOLD       = '#c8a84b';
  var GOLD_DIM   = '#8a6f30';
  var GOLD_FAINT = 'rgba(200,168,75,0.15)';
  var PARCH      = '#ede0c4';
  var PARCH_MID  = '#d9c9a3';
  var MUTED      = '#7a6e5a';
  var LINE       = 'rgba(200,168,75,0.2)';

  // ── Datos ────────────────────────────────────────────────
  var grafo = {
    series: [
      {
        titulo: 'Que le prometio Dios a Abraham?',
        tituloDisplay: '\u00bfQu\u00e9 le prometi\u00f3 Dios a Abraham?',
        partes: [
          { label: 'Parte 1', sub: 'El llamado, la aventura y la promesa',      slug: 'que-le-prometio-dios-a-abraham-p1' },
          { label: 'Parte 2', sub: 'Hebreos, Nehe\u006d\u00edas y la resurrecci\u00f3n',       slug: 'que-le-prometio-dios-a-abraham-p2' },
          { label: 'Parte 3', sub: 'Isaac, el Dios de vivos y el d\u00eda postrero',  slug: 'que-le-prometio-dios-a-abraham-p3', bifurca: true },
        ]
      }
    ],
    bifurcacion: [
      {
        tituloDisplay: 'Siglo Presente, Mundo Venidero',
        partes: [
          { label: 'Parte 1', sub: 'Las dos eras y el Reino Perdido',            slug: 'siglo-presente-mundo-venidero-p1' },
          { label: 'Parte 2', sub: 'El ladr\u00f3n de la cruz y el reino restaurado', slug: 'siglo-presente-mundo-venidero-p2' },
          { label: 'Parte 3', sub: 'El misterio del reino de mil a\u00f1os',          slug: 'siglo-presente-mundo-venidero-p3' },
        ]
      },
      {
        tituloDisplay: 'La Simiente de Abraham',
        partes: [
          { label: 'Parte 1', sub: 'El candidato que Dios eligi\u00f3 para heredar el mundo', slug: 'la-simiente-de-abraham-p1' },
        ]
      }
    ]
  };

  // ── Helpers ──────────────────────────────────────────────
  function isActive(slug) {
    var href = '/articulos/' + slug;
    return currentPath === href || currentPath === href + '/';
  }

  function makeLink(slug) {
    var a = document.createElement('a');
    a.href = '/articulos/' + slug;
    a.style.cssText = 'text-decoration:none;display:block;';
    return a;
  }

  function makeRow(parte) {
    var activa = isActive(parte.slug);
    var wrap = makeLink(parte.slug);
    wrap.style.cssText += 'display:flex;align-items:baseline;gap:0.6rem;padding:0.3rem 0.5rem;border-radius:4px;transition:background 0.2s;';
    if (activa) wrap.style.background = 'rgba(200,168,75,0.07)';
    wrap.onmouseenter = function() { if (!activa) this.style.background = 'rgba(200,168,75,0.04)'; };
    wrap.onmouseleave = function() { if (!activa) this.style.background = 'transparent'; };

    var label = document.createElement('span');
    label.textContent = parte.label;
    label.style.cssText = 'font-family:Cormorant SC,serif;font-size:0.68rem;letter-spacing:0.2em;flex-shrink:0;color:' + (activa ? GOLD : GOLD_DIM) + ';';

    var sub = document.createElement('span');
    sub.textContent = parte.sub;
    sub.style.cssText = 'font-family:EB Garamond,Georgia,serif;font-size:0.95rem;font-style:italic;line-height:1.3;color:' + (activa ? PARCH : PARCH_MID) + ';';

    if (activa) {
      var pin = document.createElement('span');
      pin.innerHTML = '\u25c6';
      pin.style.cssText = 'font-size:0.5rem;color:' + GOLD + ';flex-shrink:0;align-self:center;';
      wrap.appendChild(pin);
    }
    wrap.appendChild(label);
    wrap.appendChild(sub);
    return wrap;
  }

  function makeBranch(serieData) {
    var branch = document.createElement('div');
    branch.style.cssText = 'padding-left:1.2rem;border-left:1px solid ' + LINE + ';margin-top:0.5rem;';

    var titulo = document.createElement('div');
    titulo.textContent = serieData.tituloDisplay;
    titulo.style.cssText = 'font-family:Cormorant Garamond,Georgia,serif;font-size:1rem;font-style:italic;color:' + PARCH + ';margin-bottom:0.4rem;padding:0.2rem 0;';
    branch.appendChild(titulo);

    var partes = document.createElement('div');
    partes.style.cssText = 'padding-left:0.8rem;border-left:1px solid ' + LINE + ';display:flex;flex-direction:column;gap:0.1rem;';
    serieData.partes.forEach(function(p) { partes.appendChild(makeRow(p)); });
    branch.appendChild(partes);
    return branch;
  }

  // ── Construir contenido ──────────────────────────────────
  var seriesContainer = document.createElement('div');
  seriesContainer.style.cssText = 'display:flex;flex-direction:column;gap:0;';

  // Serie principal (QLPDA)
  var serie = grafo.series[0];
  var mainWrap = document.createElement('div');

  var mainTitulo = document.createElement('div');
  mainTitulo.textContent = serie.tituloDisplay;
  mainTitulo.style.cssText = 'font-family:Cormorant Garamond,Georgia,serif;font-size:1.1rem;font-style:italic;font-weight:400;color:' + PARCH + ';margin-bottom:0.5rem;';
  mainWrap.appendChild(mainTitulo);

  var mainPartes = document.createElement('div');
  mainPartes.style.cssText = 'padding-left:0.8rem;border-left:1px solid ' + LINE + ';display:flex;flex-direction:column;gap:0.1rem;';

  serie.partes.forEach(function(parte, i) {
    mainPartes.appendChild(makeRow(parte));

    // Insertar bifurcaci\u00f3n despu\u00e9s de la \u00faltima parte
    if (parte.bifurca) {
      var bifWrap = document.createElement('div');
      bifWrap.style.cssText = 'margin-top:0.8rem;padding-left:0.6rem;';

      var bifLabel = document.createElement('div');
      bifLabel.textContent = 'A partir de aqu\u00ed, dos caminos:';
      bifLabel.style.cssText = 'font-family:Cormorant SC,serif;font-size:0.9rem;letter-spacing:0.22em;color:' + MUTED + ';text-transform:uppercase;margin-bottom:0.6rem;';
      bifWrap.appendChild(bifLabel);

      var bifBranches = document.createElement('div');
      bifBranches.style.cssText = 'display:flex;flex-direction:column;gap:1rem;';
      grafo.bifurcacion.forEach(function(b) {
        bifBranches.appendChild(makeBranch(b));
      });
      bifWrap.appendChild(bifBranches);
      mainPartes.appendChild(bifWrap);
    }
  });

  mainWrap.appendChild(mainPartes);
  seriesContainer.appendChild(mainWrap);

  panel.appendChild(header);
  panel.appendChild(seriesContainer);
  modal.appendChild(backdrop);
  modal.appendChild(panel);
  document.body.appendChild(modal);

  function openMapa() {
    modal.style.display = 'flex';
    requestAnimationFrame(function() {
      backdrop.style.opacity = '1';
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
    });
  }

  function closeMapa() {
    backdrop.style.opacity = '0';
    panel.style.opacity = '0';
    panel.style.transform = 'translateY(16px)';
    setTimeout(function() { modal.style.display = 'none'; }, 260);
  }

  var isOpen = false;

  document.addEventListener('click', function(e) {
    if (e.target.closest('#mapa-trigger')) {
      isOpen ? closeMapa() : openMapa();
      isOpen = !isOpen;
      return;
    }
    if (e.target.closest('#mapa-close')) {
      closeMapa();
      isOpen = false;
      return;
    }
    if (isOpen && e.target === backdrop) {
      closeMapa();
      isOpen = false;
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) {
      closeMapa();
      isOpen = false;
    }
  });

})();
</script>
